{
  "id": "toongod",
  "name": "Toongod",
  "version": "1.0.4",
  "manifestURI": "https://raw.githubusercontent.com/branrgx/seanime-extensions/main/src/Toongod/manifest.json",
  "language": "typescript",
  "type": "manga-provider",
  "description": "An extension for Seanime for Toongod, which is a website that publishes Korean, Japanese, and Chinese comics in English.",
  "author": "branrgx",
  "icon": "https://raw.githubusercontent.com/branrgx/seanime-extensions/main/src/Toongod/icon.png",
  "lang": "en",
  "payloadURI": "https://raw.githubusercontent.com/branrgx/seanime-extensions/main/src/Toongod/main.ts",
  "userConfig": {
    "requiresConfig": false,
    "version": 1,
    "fields": [
      {
        "name": "useProxyBypass",
        "label": "Use proxy cloudflare bypass",
        "type": "switch",
        "default": "true"
      },
      {
        "name": "proxyBypassUrl",
        "label": "FlareSolverr Proxy URL",
        "type": "text",
        "default": "http://127.0.0.1:8191"
      }
    ]
  }
}
